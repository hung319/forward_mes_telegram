# ============ TELEGRAM API ============
API_ID=123456
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token

# ============ DATABASE ============
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=forward_bot

# ============ ADMIN ============
ADMIN_IDS=123456789

# ============ LOGGER ============
LOG_FILE=message_ids.log

# ============ SYNC (Log → DB) ============
SYNC_INTERVAL=300  # seconds (default: 5 minutes)

# ============ REALTIME FORWARD ============
REALTIME_CHECK_INTERVAL=3  # seconds between checks
REALTIME_BATCH_SIZE=10  # messages per batch

# ============ DEFAULT FORWARD OPTIONS ============
DEFAULT_REMOVE_CAPTION=false
DEFAULT_REMOVE_FORWARD_HEADER=false
DEFAULT_MIN_DURATION=0  # seconds (0 = any)
DEFAULT_MAX_DURATION=0  # seconds (0 = no limit)
DEFAULT_MIN_FILE_SIZE=0  # bytes (0 = any)
DEFAULT_MAX_FILE_SIZE=0  # bytes (0 = no limit)

# ============ DEFAULT MEDIA TYPES ============
# Options: video,photo,document,audio,voice,video_note,sticker,animation,text,all
# Multiple: comma-separated (e.g., video,photo,document)
DEFAULT_MEDIA_TYPES=all

# ============ DEFAULT CONTENT FILTERS ============
DEFAULT_REQUIRE_CAPTION=false
DEFAULT_REQUIRE_HASHTAGS=false
# Block keywords (comma-separated)
DEFAULT_BLOCK_LIST=

# ============ OTHER ============
SESSIONS_FOLDER=sessions
FLOOD_WAIT_DELAY=5  # seconds
MESSAGE_DELAY=0.5  # seconds between messages
