# Telegram API
API_ID=123456
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token

# MongoDB
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=forward_bot

# Admin
ADMIN_IDS=123456789

# Logger - Log forwarded message IDs to file
LOG_FILE=message_ids.log

# Sync - Interval in seconds to sync from log file to DB (default: 300 = 5 minutes)
SYNC_INTERVAL=300